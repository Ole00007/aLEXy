RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=LexFlow
WEBHOOK_SECRET=your_webhook_secret_here
ADMIN_EMAIL=your_admin_email_here
# Google Calendar OAuth2 - credentials file path (never commit this file)
# Generate at https://cloud.google.com/console
# Scope: https://www.googleapis.com/auth/calendar.events only
GOOGLE_CLIENT_SECRET_PATH=/path/to/google_client_secret.json

